# Factus MCP Server — Environment Configuration
# Copy this file to .env and fill in your credentials.
# NEVER commit the .env file with real secrets.

# Environment: "sandbox" or "production"
ENV=sandbox

# Factus API credentials
FACTUS_CLIENT_ID=your_client_id_here
FACTUS_CLIENT_SECRET=your_client_secret_here
FACTUS_USERNAME=your_email@example.com
FACTUS_PASSWORD=your_password_here

# MCP Evaluation Key (provided by OpenCode/Agent Teams)
MCP_EVALUATION_KEY=your_evaluation_key_here

# Database URL (optional, defaults to SQLite)
# DATABASE_URL=sqlite+aiosqlite:///factus.db
